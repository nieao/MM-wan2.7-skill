# ===== 阿里云百炼 DashScope（Wan2.7 + Qwen 共用同一个 Key，推荐）=====
# 申请地址：https://bailian.console.aliyun.com/  → 右上角切换地域 → API-Key 页
# 一个 Key 同时驱动文生图（Wan2.7）和文案生成（Qwen 系列）
#
# ⚠️ 注意：必须使用百炼通用 API Key（格式：sk-xxx）
#         不要用 Coding Plan 专属 Key（格式：sk-sp-xxx），那是 claude code 套餐用的
DASHSCOPE_API_KEY=

# 地域选择：beijing（默认）/ singapore / us
# 北京：https://dashscope.aliyuncs.com/compatible-mode/v1
# 新加坡：https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 美西：https://dashscope-us.aliyuncs.com/compatible-mode/v1
DASHSCOPE_REGION=beijing

# ----- Wan 文生图模型 -----
# wan2.2-t2i-flash  快速版（推荐起步）
# wan2.2-t2i-plus   高质量版
# wan2.7-image  比赛指定模型（默认）
# wan2.2-t2i-flash  老版本快速模型
WANXIANG_MODEL=wan2.7-image

# ----- Qwen 文案模型（按场景选）-----
# qwen-max          ⭐ 最强中文创意，出梗最妙，适合最终成品（贵一点）
# qwen-plus         性价比之选，质量已经够用（默认）
# qwen-turbo        最快最便宜，适合批量预筛
# qwen3-235b-a22b   Qwen3 旗舰 MoE，需开通
# qwen3-32b         Qwen3 中等
QWEN_MODEL=qwen-plus

# ===== 备选 LLM provider（可选，留空自动跳过）=====
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# ===== 输出目录 =====
OUTPUT_DIR=./output
